# Host port used by Docker Compose. Browse to http://localhost:8080 by default.
APP_PORT=8080

# Local MongoDB credentials used by compose.yaml.
# Keep these URL-safe: letters, numbers, hyphen and underscore are simplest.
MONGO_ROOT_USERNAME=wanderlust
MONGO_ROOT_PASSWORD=change_this_local_mongo_password

# Express session encryption/signing secret. Generate a long random value.
SECRET=replace_with_a_long_random_secret

# Mapbox token used for geocoding and rendering maps.
MAP_TOKEN=pk.replace_with_your_mapbox_token

# Cloudinary credentials used for listing image uploads.
CLOUD_NAME=replace_with_cloudinary_cloud_name
CLOUD_API_KEY=replace_with_cloudinary_api_key
CLOUD_API_SECRET=replace_with_cloudinary_api_secret

# Keep false for local HTTP. Set true only when the app is served through HTTPS.
COOKIE_SECURE=false

# Optional seed-account settings used by: docker compose run --rm app npm run seed
SEED_USERNAME=demo
SEED_EMAIL=demo@example.com
SEED_PASSWORD=ChangeMe123!

dbUrl=mongodb+srv://<db_username>:xobMOrq4xlVe8H71@wander-list.w0x70wi.mongodb.net/?appName=Wander-list
